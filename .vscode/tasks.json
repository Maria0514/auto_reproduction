{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "启动 Streamlit 界面",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/streamlit",
            "args": [
                "run",
                "app.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": [],
            "detail": "在本地启动论文复现系统的 Streamlit 前端（app.py）"
        },
        {
            "label": "跑测试：非 e2e（快）",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pytest",
            "args": [
                "-q",
                "-m",
                "not e2e"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [],
            "detail": "只跑 mock/集成单测，跳过真实 LLM e2e（最常用，秒级）"
        },
        {
            "label": "跑测试：全量（含 e2e，慢，需凭证）",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pytest",
            "args": [
                "-q"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [],
            "detail": "跑包含真实 LLM 链路 e2e 的全量回归（凭证缺失会自动 skip）"
        },
        {
            "label": "跑测试：当前打开的文件",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pytest",
            "args": [
                "-v",
                "${file}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [],
            "detail": "对编辑器中当前打开的测试文件单独跑 pytest -v"
        }
    ]
}
