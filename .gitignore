# 运行时产物（git clone 的仓库 / 日志 / 运行记录）
# 注意区分：workspace/（单数）= 流水线运行时产物，忽略；
# workspaces/（复数）= spike 验证的 checkpoint sqlite 存档（spike_s1/s2/s3，
# 由 scripts/spike_*.py 写入），作为 spike 报告物证保留在版本控制中
workspace/

# 一次性调试探针与个人脚本（不进版本控制）
_probe_*.py
_probe_*.txt
scripts/dump_real_plan.py
scripts/shot_review.py
scripts/shot_theme.py

# LangGraph SqliteSaver 运行时 checkpoint 数据库（含 WAL 模式伴生文件 -shm/-wal）
checkpoints.db*

# 个人面试速览用 HTML 项目报告（不进版本控制）
docs/reports/
